APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR
APP_TIMEZONE=Europe/Istanbul

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# Mobile (Expo push + DNS wizard)
EXPO_PUSH_ENABLED=true
DNS_CNAME_TARGET=proxy.randevuajandam.com
# DNS_A_RECORD=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=e_posta_adresiniz@alan_adiniz.com
MAIL_PASSWORD=e_posta_sifreniz
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="e_posta_adresiniz@alan_adiniz.com"
MAIL_FROM_NAME="Randevu Ajandam"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Ã–deme (iyzico) ---
# Local/sandbox:
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Production LIVE:
# IYZICO_BASE_URL=https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"
# Shared secret for webhook signature (X-Iyzico-Signature or X-Webhook-Secret). Required in production.
IYZICO_WEBHOOK_SECRET=
# Only for local/testing: allow mock subscription success when API is unreachable. NEVER true in production.
IYZICO_ALLOW_MOCK=false

# --- SMS ---
# Supported drivers: netgsm, iletimerkezi, log (log only for local)
SMS_DRIVER=log

NETGSM_USER=netgsm_kullanici_adiniz
NETGSM_PASS=netgsm_sifreniz
NETGSM_HEADER=netgsm_basliginiz

ILETIMERKEZI_KEY=iletimerkezi_api_key
ILETIMERKEZI_HASH=iletimerkezi_api_hash
ILETIMERKEZI_SENDER=iletimerkezi_gonderici_adiniz

# Misafir randevu OTP (production Ã¶nerilir: true)
RANDEVU_OTP_REQUIRED=false

# --- Hostinger (pakete dahil domain: mÃ¼saitlik + satÄ±n alma) ---
# Token: hPanel â†’ Account â†’ API  |  Domain Ã¼creti mÃ¼ÅŸteriye yansÄ±tÄ±lmaz
HOSTINGER_ENABLED=false
HOSTINGER_API_TOKEN=
HOSTINGER_BASE_URL=https://developers.hostinger.com
HOSTINGER_PAYMENT_METHOD_ID=
HOSTINGER_DEFAULT_TLDS=com,net
HOSTINGER_AVAILABILITY_PER_MINUTE=8
HOSTINGER_CATALOG_CACHE_TTL=21600
HOSTINGER_TIMEOUT=25

